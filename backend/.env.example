# SafeHaven Backend -- Environment Variables
# Copy this file to .env and fill in your keys.

# Google Maps Platform -- used for geocoding, reverse geocoding, and Places API
GOOGLE_MAPS_API_KEY=

# Google Gemini -- used for AI-generated safety reports
GEMINI_API_KEY=

# Stripe -- used for donation checkout
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
